# Gateway-aware kubectl wrapper.
#
# Runs kubectl inside the active gateway's k3s container via
# `clustershell doctor exec`.  All arguments are forwarded to kubectl.
#
# Usage:
#   kubectl get pods -A
#   kubectl logs -n clustershell statefulset/clustershell

exec clustershell doctor exec -- kubectl "$@"
