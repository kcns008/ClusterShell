ARG PYTHON_VERSION=3.12

FROM --platform=$BUILDPLATFORM python:${PYTHON_VERSION}-slim AS base

ENV PATH="/root/.cargo/bin:${PATH}"

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    gcc \
    libc6-dev \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
RUN pip install --no-cache-dir maturin

COPY deploy/docker/cross-build.sh /usr/local/bin/

FROM base AS builder

ARG TARGETARCH
ARG BUILDARCH
ARG CARGO_TARGET_CACHE_SCOPE=default

ARG SCCACHE_MEMCACHED_ENDPOINT

WORKDIR /build

RUN . cross-build.sh && install_cross_toolchain && install_sccache && add_rust_target

# Copy dependency manifests first for better caching.
COPY Cargo.toml Cargo.lock ./
COPY crates/clustershell-cli/Cargo.toml crates/clustershell-cli/Cargo.toml
COPY crates/clustershell-core/Cargo.toml crates/clustershell-core/Cargo.toml
COPY crates/clustershell-providers/Cargo.toml crates/clustershell-providers/Cargo.toml
COPY crates/clustershell-router/Cargo.toml crates/clustershell-router/Cargo.toml
COPY crates/clustershell-sandbox/Cargo.toml crates/clustershell-sandbox/Cargo.toml
COPY crates/clustershell-server/Cargo.toml crates/clustershell-server/Cargo.toml
COPY crates/clustershell-bootstrap/Cargo.toml crates/clustershell-bootstrap/Cargo.toml
COPY crates/clustershell-core/build.rs crates/clustershell-core/build.rs
COPY proto/ proto/

# Create dummy source files to build dependencies.
RUN mkdir -p crates/clustershell-cli/src crates/clustershell-core/src crates/clustershell-providers/src crates/clustershell-router/src crates/clustershell-sandbox/src crates/clustershell-server/src crates/clustershell-bootstrap/src && \
    echo "fn main() {}" > crates/clustershell-cli/src/main.rs && \
    echo "fn main() {}" > crates/clustershell-sandbox/src/main.rs && \
    echo "fn main() {}" > crates/clustershell-server/src/main.rs && \
    touch crates/clustershell-core/src/lib.rs && \
    touch crates/clustershell-providers/src/lib.rs && \
    touch crates/clustershell-router/src/lib.rs && \
    touch crates/clustershell-bootstrap/src/lib.rs

# Build dependencies only (cached unless Cargo.toml/lock changes).
# sccache uses memcached in CI or the local disk cache mount for local dev.
# The cargo-target mount gives cargo a persistent target/ dir for incremental rebuilds.
RUN --mount=type=cache,id=cargo-registry-python-wheels-${TARGETARCH},sharing=locked,target=/root/.cargo/registry \
    --mount=type=cache,id=cargo-git-python-wheels-${TARGETARCH},sharing=locked,target=/root/.cargo/git \
    --mount=type=cache,id=cargo-target-python-wheels-${TARGETARCH}-${CARGO_TARGET_CACHE_SCOPE},sharing=locked,target=/build/target \
    --mount=type=cache,id=sccache-python-wheels-${TARGETARCH},sharing=locked,target=/tmp/sccache \
    . cross-build.sh && cargo_cross_build --release -p clustershell-cli 2>/dev/null || true

# Copy actual source code and Python packaging files.
COPY crates/ crates/
COPY pyproject.toml README.md ./
COPY python/ python/

# Touch source files to ensure they're rebuilt (not the cached dummy).
RUN touch crates/clustershell-cli/src/main.rs \
    crates/clustershell-cli/src/lib.rs \
    crates/clustershell-bootstrap/src/lib.rs \
    crates/clustershell-core/src/lib.rs \
    crates/clustershell-providers/src/lib.rs \
    crates/clustershell-router/src/lib.rs \
    crates/clustershell-sandbox/src/main.rs \
    crates/clustershell-server/src/main.rs \
    crates/clustershell-core/build.rs \
    proto/*.proto

# Declare version ARGs here (not earlier) so the git-hash-bearing values do not
# invalidate the expensive dependency-build layers above on every commit.
ARG CLUSTERSHELL_CARGO_VERSION
ARG CLUSTERSHELL_IMAGE_TAG
RUN --mount=type=cache,id=cargo-registry-python-wheels-${TARGETARCH},sharing=locked,target=/root/.cargo/registry \
    --mount=type=cache,id=cargo-git-python-wheels-${TARGETARCH},sharing=locked,target=/root/.cargo/git \
    --mount=type=cache,id=cargo-target-python-wheels-${TARGETARCH}-${CARGO_TARGET_CACHE_SCOPE},sharing=locked,target=/build/target \
    --mount=type=cache,id=sccache-python-wheels-${TARGETARCH},sharing=locked,target=/tmp/sccache \
    . cross-build.sh && \
    export_cross_env && \
    export RUSTC_WRAPPER=sccache && \
    export CARGO_BUILD_TARGET="$(rust_target)" && \
    if [ -n "${CLUSTERSHELL_CARGO_VERSION:-}" ]; then \
      sed -i -E '/^\[workspace\.package\]/,/^\[/{s/^version[[:space:]]*=[[:space:]]*".*"/version = "'"${CLUSTERSHELL_CARGO_VERSION}"'"/}' Cargo.toml; \
    fi && \
    maturin build --release --target "${CARGO_BUILD_TARGET}" --out /wheels

FROM scratch AS wheels
COPY --from=builder /wheels/*.whl /
